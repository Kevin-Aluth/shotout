pico-8 cartridge // http://www.pico-8.com
version 41
__lua__
rad=1
is_shrinking=false
col=1

function _update60()
	cls()
	if is_shrinking then
		rad-=0.5
	else
		rad+=0.5
	end
	
	if rad>50 then
		is_shrinking=true
	end
	if rad<2 then
		is_shrinking=false
	end
	
	col+=0.2
	circfill(64,64,rad,col)
end
